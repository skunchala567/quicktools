    "generator",
    "excel",
    "tools",
    "image",
    "messaging"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.5.0",
    "http-server": "^14.1.1",
    "live-server": "^1.2.2",
    "prettier": "^3.8.4"
  }
}
