{
  "name": "quicktools",
  "version": "1.0.0",
  "description": "Professional QR Code, Excel, Image, and Messaging Tools Suite",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "live-server --port=3000",
    "serve": "http-server -p 3000 -o",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
